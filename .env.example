# StayMate — copy to `.env.local` and fill values as you wire features.
# None of these are required for the UI stub / mock-data skeleton.

# -----------------------------------------------------------------------------
# App (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Backend API (future)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:8080
# API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Auth — Google OAuth (future: Auth.js / NextAuth)
# -----------------------------------------------------------------------------
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OpenAI (future: server-side chat — never expose with NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Speech — Whisper or compatible transcribe endpoint (future)
# -----------------------------------------------------------------------------
# TRANSCRIBE_API_URL=
# TRANSCRIBE_API_KEY=
